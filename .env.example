# Copy to `.env` and/or `.env.local` next to package.json. Restart `npm run dev` after edits.
# `.env.local` overrides `.env` for the same variable name.

DATABASE_URL="file:./dev.db"

# xAI — chat/vision pipeline (lib/xai-openai.ts, lib/pipeline.ts) + Grok Imagine video (lib/video.ts).
XAI_API_KEY=

# Optional overrides (defaults: fast Grok 4 for vision + text; check console.x.ai for your team)
# XAI_VISION_MODEL=grok-4-1-fast-non-reasoning
# XAI_TEXT_MODEL=grok-4-1-fast-non-reasoning

# ElevenLabs TTS (lib/voice.ts).
ELEVENLABS_API_KEY=

# Optional: video backend selector when multiple exist.
# VIDEO_PROVIDER=grok-imagine
