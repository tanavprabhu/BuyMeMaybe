# PostgreSQL (local Docker, Neon, Supabase, RDS, …)
# Neon: https://neon.tech — copy the connection string with ?sslmode=require
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public"

# xAI (Grok chat / vision / video) — required in production on your host (e.g. Vercel env vars)
XAI_API_KEY=

# Optional model overrides (defaults in lib/pipeline.ts)
# XAI_VISION_MODEL=
# XAI_TEXT_MODEL=

# Vercel Blob (required on Vercel: serverless cannot write under public/)
# Storage → Blob → link project → BLOB_READ_WRITE_TOKEN is injected in prod
BLOB_READ_WRITE_TOKEN=
